# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Web Search (Responses API) khi sản phẩm không có trong catalog
ENABLE_OPENAI_WEB_SEARCH=true
OPENAI_WEB_SEARCH_MODEL=gpt-4o

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here

# LOCAL LLM SETTINGS (GGUF via llama-cpp)
# Download model from: https://huggingface.co/microsoft/Phi-3-mini-4k-instruct-gguf
LOCAL_MODEL_PATH=./models/Phi-3-mini-4k-instruct-q4.gguf

# LAB CONFIG
# Options: openai | google | local
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
LOG_LEVEL=INFO

# Optional: path to product catalog JSON (default: ./data/products_catalog.json)
# PRODUCTS_CATALOG_PATH=./data/products_catalog.json

# API server (run_api.py)
# API_HOST=0.0.0.0
# API_PORT=8000
